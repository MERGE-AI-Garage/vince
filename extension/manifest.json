{
  "manifest_version": 3,
  "name": "Brand Lens",
  "version": "1.0.0",
  "description": "AI-powered brand intelligence with prompt builder — your brand toolkit for any AI tool",
  "permissions": ["sidePanel", "storage", "identity", "activeTab"],
  "host_permissions": [
    "https://foolpmhiedplyftbiocb.supabase.co/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": "icons/icon-48.png",
    "default_title": "Brand Lens"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
